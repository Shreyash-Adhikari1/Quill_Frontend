# Keep host dependencies out of the image.
# The container installs Linux-compatible dependencies with npm ci.
node_modules

# Ignore local Next.js build output because the container builds fresh output.
.next
out
build

# Never bake local secrets into the frontend image.
# NEXT_PUBLIC_* values are supplied by docker-compose at build/runtime boundaries.
.env
.env.*
!.env.example

# TLS private keys remain on the host, not inside the image.
certs/

# Git metadata and editor noise are unnecessary in the Docker context.
.git
.gitignore
.vscode
.idea

# Local logs and package-manager debug output do not belong in the image.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Documentation is excluded to reduce build context size.
README.md
*.md

# Optional local formatting configs are not needed at runtime.
.eslintrc*
.prettierrc*
